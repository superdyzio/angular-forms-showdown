    "@ngx-translate/http-loader": "^17.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "~5.1.15",
    "angular-eslint": "21.3.1",
